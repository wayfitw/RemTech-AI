# ── Окружение ────────────────────────────────────────────────────────────────
# development | production. В production включается гейт обязательных секретов:
# JWT_SECRET (не дефолт, ≥32 симв.), DATABASE_URL, CORS_ORIGINS.
APP_ENV=development

# ── Авторизация ──────────────────────────────────────────────────────────────
# Сгенерируй длинный случайный секрет, напр.: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_TTL_HOURS=24

# ── База данных / очереди ─────────────────────────────────────────────────────
# В Docker Compose DATABASE_URL/REDIS_URL задаются автоматически из compose.
# Для локального запуска без Docker укажи свой адрес Postgres:
DATABASE_URL=postgresql+asyncpg://remtech:remtech@localhost:5432/remtech
DB_COMMAND_TIMEOUT=30               # таймаут запроса к БД, сек (issue #17)
DB_POOL_RECYCLE=1800               # пересоздание соединений, сек
DB_SSL=false                       # true → TLS к внешнему Postgres
REDIS_URL=redis://localhost:6379/0
ORCHESTRATOR_STATE_BACKEND=memory   # memory (один процесс) | redis (масштабирование, issue #16)
# Креды Postgres/Redis для docker-compose (в production задай сильные уникальные):
POSTGRES_USER=remtech
POSTGRES_PASSWORD=remtech
POSTGRES_DB=remtech
REDIS_PASSWORD=remtech-redis

# ── Шлюз моделей (LLM gateway) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001
MAX_TOKENS=16000
DEFAULT_MODEL=claude            # алиас основной модели (реестр model_configs)
FALLBACK_MODEL=claude-fast      # резерв при недоступности основной — быстрая модель того же провайдера
EGRESS_PROXY_URL=               # обратный прокси к зарубежным моделям (стадия 2b)
VLLM_BASE_URL=                  # локальная модель для приватного контура (стадия 2b)

# ── Медиа (картинки/видео) ────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...

# ── Telegram-канал (issue #31) — токен от @BotFather, бесплатный ────────────────
TELEGRAM_BOT_TOKEN=                                   # пусто → бот не стартует
TELEGRAM_POLL_TIMEOUT=25                              # long polling getUpdates, сек
# Allow-list связывания аккаунтов (управляет администратор):
#   "<telegram_id>:<username>,<telegram_id>:<username>"
TELEGRAM_ALLOWLIST=
# Персона бота: имя агента (Telegram = личный ассистент директора). Пусто → дефолт.
# Агенты создаются: python -m scripts.seed_agents
TELEGRAM_AGENT=

# ── RAG / эмбеддинги ──────────────────────────────────────────────────────────
EMBED_BACKEND=ollama            # ollama | fake (fake — детерминированный, для тестов/без GPU)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=bge-m3
EMBED_DIM=1024
KB_TOP_K=5
KB_RERANK_CANDIDATES=20         # #39 — кандидатов top-N на 1-й стадии (косинус) под реранк
KB_ASYNC_INGEST=false           # true → ингест БЗ через Celery-воркер (нужен сервис worker)
# #39 — TEI-реранкер (bge-reranker) на GPU: пусто → одностадийный поиск (без GPU);
# в GPU-профиле compose задать http://tei:80 (двухстадийный: косинус top-N → реранк → top_k)
TEI_URL=

# ── Почта (IMAP, чтение писем ассистентом) ────────────────────────────────────
# Логин = адрес, пароль = ПАРОЛЬ ПРИЛОЖЕНИЯ (не основной пароль аккаунта).
# Gmail: Google Account → Security → App passwords (нужна 2FA). Пусто → «не настроено».
GMAIL_IMAP_USER=
GMAIL_IMAP_PASSWORD=
# Яндекс: Яндекс ID → Пароли приложений → «Почта (IMAP)».
YANDEX_IMAP_USER=
YANDEX_IMAP_PASSWORD=
# Как часто проверять новые письма для пуш-уведомлений в бот (сек).
MAIL_POLL_SECONDS=120

# ── Telethon (чтение ТГ-чатов/групп от лица пользователя) ─────────────────────
# api_id/api_hash — с https://my.telegram.org. Сессия создаётся входом по QR:
#   python -m scripts.telethon_login  → впиши выданную строку в TELETHON_SESSION.
# Сессия = доступ к твоему ТГ-аккаунту (чтение чатов) — храни как секрет.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION=
# Группы для утренней сводки (через запятую: @username или id) и час дайджеста (местный).
TG_DIGEST_GROUPS=
TG_DIGEST_HOUR=7

# ── Файлы / документы ─────────────────────────────────────────────────────────
FILES_DIR=data/files
# Путь к TTF-шрифту с кириллицей для PDF. Пусто — авто-дефолт по ОС.
PDF_FONT_PATH=
LOGO_PATH=

# ── Сервер / CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Caddy (HTTPS в ЛВС) ───────────────────────────────────────────────────────
# Адрес сайта для Caddy: домен ЛВС (даст авто-HTTPS) или :80 для проверки.
# SITE_ADDRESS=remtech.local

# ── Голос (EPIC-10) — STT локальным Whisper (issue #34); по умолчанию выключено ──
STT_ENABLED=false
STT_BACKEND=null                 # null (заглушка) | whisper (faster-whisper)
STT_MODEL=small                  # tiny|base|small|medium|large-v3
STT_LANGUAGE=ru                  # язык распознавания (пусто → авто)
STT_DEVICE=cpu                   # cpu | cuda
STT_COMPUTE_TYPE=int8            # int8 (CPU) | float16 (GPU)
TTS_ENABLED=false
TTS_BACKEND=silence             # silence (заглушка) | silero (torch)
TTS_MODEL=v4_ru                 # пакет голосов Silero (ru)
TTS_SPEAKER=xenia               # aidar|baya|kseniya|xenia|eugene
TTS_SAMPLE_RATE=48000           # 8000|24000|48000 (48000 — под opus/sendVoice)
TTS_DEVICE=cpu
